# ─────────────────────────────────────────────────────────────────────────────
# GOALTIFY — Environment Variables
# Copy this file to .env.local and fill in your keys
# NEVER commit .env.local to GitHub
# ─────────────────────────────────────────────────────────────────────────────

# ── Live Scores API (football-data.org) ───────────────────────────────────────
# Previously: api-football.com (api-sports.io) — REPLACED with football-data.org
# Get free key at: https://www.football-data.org/client/register
# Free tier: 10 req/min, top competitions (PL, CL, WC, La Liga, etc.) free forever
# Paid: starts at ~$6/mo for more competitions + faster polling
FOOTBALL_DATA_API_KEY=your_football_data_api_key_here

# ── News API ──────────────────────────────────────────────────────────────────
# Get free key at: https://newsapi.org/register
# Free tier: 100 req/day (dev only) | Paid: $449/mo for production
# Alternative: GNews (https://gnews.io) — 100 req/day free, cheaper paid
NEWS_API_KEY=your_news_api_key_here

# ── Anthropic Claude API (Phase 2 — auto article generation) ─────────────────
# Get key at: https://console.anthropic.com
# Used by GitHub Actions to auto-generate SEO articles weekly
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Google Analytics (optional) ───────────────────────────────────────────────
# Get from: https://analytics.google.com → Admin → Data Streams
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://goaltify.com

# ─────────────────────────────────────────────────────────────────────────────
# WHERE TO ADD KEYS IN VERCEL (production):
# Dashboard → Your Project → Settings → Environment Variables
# Add each key above as a separate variable
# Football + News + Anthropic = Server only (no NEXT_PUBLIC_ prefix)
# GA_ID = needs NEXT_PUBLIC_ prefix so browser can read it
# ─────────────────────────────────────────────────────────────────────────────

# ── Agent (AI auto-publishing) ────────────────────────────────────────────────
# Secret password to access /agent dashboard and protect API routes
AGENT_SECRET=choose_a_strong_password_here

# GitHub — for auto-publishing articles to your repo
# Create at: https://github.com/settings/tokens (needs repo scope)
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=your-username/goaltify
GITHUB_BRANCH=main

# Vercel Deploy Hook — triggers redeploy after each article publish
# Create at: Vercel Dashboard → Project → Settings → Git → Deploy Hooks
VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/your-hook-url

# Exposed to browser — used by AgentClient to authenticate publish requests
NEXT_PUBLIC_AGENT_SECRET=same_value_as_AGENT_SECRET
